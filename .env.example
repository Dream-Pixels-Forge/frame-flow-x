# Application Configuration
APP_NAME=frame-flow-x
APP_ENV=development
APP_PORT=3000

# API Keys (Add your actual keys here)
# AI/Upscaling Service API
AI_UPSCALER_API_KEY=your_api_key_here
AI_UPSCALER_ENDPOINT=https://api.upscaler-service.com

# Video Processing
VIDEO_PROCESSING_WORKERS=4
MAX_VIDEO_SIZE_MB=500
SUPPORTED_FORMATS=mp4,mov,avi,mkv,webm

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage
# For cloud storage (S3-compatible)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=frame-flow-x-storage

# Desktop App (Electron/Tauri)
ELECTRON_ENABLE_LOGGING=true
TAURI_DEBUG=true

# Database (if needed for user data/settings)
DATABASE_URL=

# Authentication (if user accounts are needed)
JWT_SECRET=your_jwt_secret_here
AUTH_PROVIDER=

# Analytics (optional)
ANALYTICS_ID=

# Feature Flags
ENABLE_CLOUD_SYNC=false
ENABLE_BATCH_PROCESSING=true
ENABLE_REAL_TIME_PREVIEW=true
